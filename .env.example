# Telnyx auth. One V2 API key authenticates Call Control, transcription,
# speak, and the LLM inference endpoint.
TELNYX_API_KEY=
# Ed25519 public key for webhook signature verification.
# Portal > Account Settings > Keys & Credentials > Public Key.
TELNYX_PUBLIC_KEY=

# Telephony identity.
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX        # E.164, the "from" number for outbound
TELNYX_CONNECTION_ID=                    # Voice API Application id (connection_id)

# Telnyx posts webhooks to the URL configured on your Call Control application
# in the portal (for example https://your-subdomain.ngrok.app/webhook). That is
# set in the Telnyx portal, not here.

# LLM inference (OpenAI-compatible). Kimi-K2.5 is Telnyx's recommended
# real-time voice model; reasoning is disabled in code for latency.
# Levers: moonshotai/Kimi-K2.6 (newer), MiniMaxAI/MiniMax-M2.7 (cheaper),
# zai-org/GLM-5.1-FP8 (smarter, slower). Confirm IDs via GET /v2/ai/models.
LLM_BASE_URL=https://api.telnyx.com/v2/ai
LLM_MODEL=moonshotai/Kimi-K2.5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=200

# STT (transcription_start). "Google" is the default for interim results, which
# drive barge-in. Use a short language code here ("en"); the enum rejects "en-US".
# STT_MODEL selects a specific model within engines that host several; leave it
# blank to use the engine's default. Valid pairings (validated at startup):
#   Google=<blank>   Deepgram=nova-2|nova-3|flux   xAI=xai/grok-stt
#   AssemblyAI=assemblyai/universal-streaming   Soniox=soniox/stt-rt-v4
#   Speechmatics=speechmatics/standard   Azure=<blank>
#   Telnyx=openai/whisper-large-v3-turbo|openai/whisper-tiny
# Engines without interim support (Telnyx, Azure) degrade barge-in to
# final-transcript-only; the agent logs stt.no_interim and omits the interim flag.
STT_ENGINE=Google
STT_LANGUAGE=en
STT_MODEL=
# Deepgram Flux turn-detection tuning (only used when STT_ENGINE=Deepgram and
# STT_MODEL=flux). Higher threshold = waits for a clearer end-of-turn, so one
# utterance is less likely to split into several finals. Leave unset for Flux
# defaults (0.7 / 5000 ms). Ranges: threshold 0.5–0.9, timeout 500–10000 ms.
# STT_EOT_THRESHOLD=0.8
# STT_EOT_TIMEOUT_MS=5000

# TTS (speak). NaturalHD handles disfluencies and is multilingual; Telnyx.Natural.*
# is lowest-latency English-only; Telnyx.Ultra.* / ElevenLabs / AWS.Polly.*-Neural
# / Azure.*Neural also work here. speak accepts the full locale ("en-US").
TTS_VOICE=Telnyx.NaturalHD.astra
TTS_LANGUAGE=en-US

# Spend and volume protection (0 disables).
MAX_CONCURRENT_CALLS=10
MAX_TOKENS_PER_CALL=0

# Server.
HOST=0.0.0.0
PORT=8000
ENV=development
LOG_LEVEL=info
